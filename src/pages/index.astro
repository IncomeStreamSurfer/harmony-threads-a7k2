---
export const prerender = false;
import Base from "../layouts/Base.astro";
import { anonClient } from "../lib/supabase";

const sb = anonClient();
let products: any[] = [];
let testimonials: any[] = [];

if (sb) {
  const [{ data: prods }, { data: tmons }] = await Promise.all([
    sb.from("products").select("id, slug, name, description, price_pence, compare_at_pence, currency, image_url, tags, is_digital").not("published_at", "is", null).order("created_at", { ascending: true }).limit(6),
    sb.from("testimonials").select("author_name, author_title, quote, rating").eq("featured", true).order("sort_order").limit(3),
  ]);
  products = prods ?? [];
  testimonials = tmons ?? [];
}

const siteUrl = Astro.site?.toString() ?? "https://harmony-threads-a7k2.vercel.app";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Harmony Threads",
  "url": siteUrl,
  "description": "Wear the music you love — premium rock music merch, graphic tees and digital downloads."
};
---

<Base
  title="Vintage Rock Music Merch | Harmony Threads"
  description="Wear your favourite bands — premium graphic tees, rare prints and music merch curated for true fans. Shop The Band T-Shirts, rock history books and more."
  structuredData={websiteSchema}
>
  <section class="relative min-h-screen flex items-center overflow-hidden pt-20">
    <div class="absolute inset-0 bg-[#1a1009]"></div>
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 80%, #c0392b 0%, transparent 50%), radial-gradient(circle at 80% 20%, #8b2020 0%, transparent 50%);"></div>
    <div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/4 select-none pointer-events-none">
      <span class="font-display text-[22vw] font-black text-white/5 leading-none whitespace-nowrap">MUSIC</span>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-24 lg:py-32 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-6">Harmony Threads — Est. 2024</p>
        <h1 class="font-display text-5xl lg:text-7xl font-bold text-white leading-[1.0] tracking-tight mb-6">
          Wear the<br />
          music<br />
          <em class="not-italic text-[#c0392b]">you love.</em>
        </h1>
        <p class="text-[#a09080] text-lg leading-relaxed max-w-md mb-10">
          Premium merch for real fans. We hand-pick every piece — from vintage-inspired graphic tees to deep-cut music history — so you wear more than a logo. You wear a story.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/shop" class="btn-primary text-sm">Shop the collection</a>
          <a href="/about" class="text-sm font-medium text-[#e8e2d6] hover:text-white transition-colors flex items-center gap-2">
            Our story
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="flex items-center gap-6 mt-10 pt-10 border-t border-white/10">
          <div><p class="text-white font-display text-2xl font-bold">140+</p><p class="text-[#6b6155] text-xs">Orders shipped</p></div>
          <div class="h-8 w-px bg-white/10"></div>
          <div><p class="text-white font-display text-2xl font-bold">5★</p><p class="text-[#6b6155] text-xs">Average rating</p></div>
          <div class="h-8 w-px bg-white/10"></div>
          <div><p class="text-white font-display text-2xl font-bold">100%</p><p class="text-[#6b6155] text-xs">Ethical cotton</p></div>
        </div>
      </div>
      <div class="relative hidden lg:block">
        <div class="relative aspect-[3/4] max-w-md ml-auto rounded-sm overflow-hidden">
          <img src="https://burst.shopifycdn.com/photos/forest-hiker.jpg?width=1000" alt="The Band Graphic T-Shirt in green" class="w-full h-full object-cover" loading="eager" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#1a1009]/60 to-transparent"></div>
          <div class="absolute bottom-6 left-6 bg-[#faf7f2] rounded-sm px-4 py-3">
            <p class="text-xs text-[#6b6155]">The Band Graphic T-Shirt</p>
            <p class="font-display text-xl font-bold text-[#1a1009]">£19.99</p>
          </div>
        </div>
        <div class="absolute -top-4 -left-4 bg-[#c0392b] text-white rounded-full w-20 h-20 flex items-center justify-center text-center">
          <span class="text-xs font-bold leading-tight">New<br />Drop</span>
        </div>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 animate-bounce">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <div class="bg-[#c0392b] py-3 overflow-hidden">
    <div class="flex animate-marquee whitespace-nowrap">
      {["Free UK shipping over £40", "30-day returns", "Ethically made", "New drops every month", "Free UK shipping over £40", "30-day returns", "Ethically made", "New drops every month"].map(text => (
        <span class="text-white text-sm font-medium px-8 flex items-center gap-4">{text}<span class="inline-block w-1.5 h-1.5 rounded-full bg-white/60"></span></span>
      ))}
    </div>
  </div>

  <section class="py-24 px-6 lg:px-12 max-w-7xl mx-auto" id="products">
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-3">The Collection</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold leading-tight">Music you can wear.<br />Stories you can keep.</h2>
      </div>
      <a href="/shop" class="hidden md:flex items-center gap-2 text-sm font-medium text-[#6b6155] hover:text-[#c0392b] transition-colors">View all <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {products.map(product => (
        <a href={`/shop/${product.slug}`} class="group">
          <div class="aspect-square overflow-hidden bg-[#f0ece4] rounded-sm relative mb-4">
            <img src={product.image_url} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            {product.compare_at_pence && product.compare_at_pence > product.price_pence && (<span class="absolute top-3 left-3 bg-[#c0392b] text-white text-xs font-semibold px-2 py-1">SALE</span>)}
            {product.is_digital && (<span class="absolute top-3 left-3 bg-[#1a1009] text-white text-xs font-semibold px-2 py-1">DIGITAL</span>)}
          </div>
          <div>
            <p class="text-xs text-[#6b6155] uppercase tracking-widest mb-1">{product.tags?.[0] ?? "Merch"}</p>
            <h3 class="font-display text-lg font-semibold leading-snug mb-2 group-hover:text-[#c0392b] transition-colors">{product.name}</h3>
            <div class="flex items-center gap-2">
              <span class="font-semibold">£{(product.price_pence / 100).toFixed(2)}</span>
              {product.compare_at_pence && product.compare_at_pence > product.price_pence && (<span class="text-sm text-[#6b6155] line-through">£{(product.compare_at_pence / 100).toFixed(2)}</span>)}
            </div>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-12 text-center md:hidden"><a href="/shop" class="btn-secondary text-sm">View all products</a></div>
  </section>

  <section class="bg-[#1a1009] py-24 px-6 lg:px-12">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Our ethos</p>
        <h2 class="font-display text-4xl lg:text-5xl font-bold text-white leading-tight mb-6">Great music<br />deserves great merch.</h2>
        <p class="text-[#a09080] leading-relaxed mb-6">We started Harmony Threads because we were tired of thin, overpriced tour tees that fell apart in the wash. Every piece we sell is printed on GOTS-certified organic cotton, designed to last as long as the records you love.</p>
        <p class="text-[#a09080] leading-relaxed mb-8">From The Band to the history of rock music in digital form — we curate for the listener who takes their music seriously.</p>
        <a href="/about" class="btn-primary text-sm">Read our story</a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="aspect-square bg-[#2d2018] rounded-sm overflow-hidden"><img src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=600&q=80" alt="Live music concert" class="w-full h-full object-cover opacity-80" loading="lazy" /></div>
        <div class="aspect-square bg-[#2d2018] rounded-sm overflow-hidden mt-8"><img src="https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=600&q=80" alt="Music performance" class="w-full h-full object-cover opacity-80" loading="lazy" /></div>
      </div>
    </div>
  </section>

  {testimonials.length > 0 && (
    <section class="py-24 px-6 lg:px-12 max-w-7xl mx-auto">
      <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-3 text-center">What fans say</p>
      <h2 class="font-display text-4xl font-bold text-center mb-16 leading-tight">Real people.<br />Real music.<br />Real quality.</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map(t => (
          <div class="bg-white border border-[#e8e2d6] p-8 rounded-sm">
            <div class="flex mb-4">{Array.from({ length: t.rating ?? 5 }).map(() => (<span class="text-[#c0392b]">★</span>))}</div>
            <blockquote class="text-[#3a3a3a] leading-relaxed mb-6 text-sm">"{t.quote}"</blockquote>
            <div><p class="font-semibold text-sm">{t.author_name}</p>{t.author_title && <p class="text-xs text-[#6b6155]">{t.author_title}</p>}</div>
          </div>
        ))}
      </div>
    </section>
  )}

  <section class="bg-[#f0ece4] py-20 px-6 lg:px-12">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-3">Stay in the loop</p>
      <h2 class="font-display text-4xl font-bold mb-4 leading-tight">New drops, stories, rare finds.</h2>
      <p class="text-[#6b6155] mb-8">Join 600+ music fans who get early access to new merch and exclusive articles.</p>
      <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="hidden" name="renderedAt" id="rendered-at" />
        <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />
        <input type="email" name="email" placeholder="your@email.com" required class="flex-1 px-4 py-3 border border-[#e8e2d6] bg-white text-sm focus:outline-none focus:border-[#c0392b]" />
        <button type="submit" class="btn-primary text-sm px-6 py-3 whitespace-nowrap">Get early access</button>
      </form>
      <p id="newsletter-msg" class="text-sm mt-3 hidden"></p>
    </div>
  </section>
</Base>

<style>
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .animate-marquee { animation: marquee 20s linear infinite; }
</style>

<script>
  document.getElementById('rendered-at')!.value = Date.now().toString();
  document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const data = new FormData(form);
    const msgEl = document.getElementById('newsletter-msg')!;
    try {
      const res = await fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: data.get('email'), website: data.get('website'), renderedAt: data.get('renderedAt') }) });
      const json = await res.json();
      msgEl.textContent = json.message ?? 'You\'re in!';
      msgEl.className = 'text-sm mt-3 text-green-700';
      form.reset();
    } catch { msgEl.textContent = 'Something went wrong.'; msgEl.className = 'text-sm mt-3 text-red-600'; }
    msgEl.classList.remove('hidden');
  });
</script>
