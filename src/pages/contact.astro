---
export const prerender = false;
import Base from "../layouts/Base.astro";

const siteUrl = Astro.site?.toString() ?? "https://harmony-threads-a7k2.vercel.app";
const contactSchema = { "@context": "https://schema.org", "@type": "ContactPage", "name": "Contact Harmony Threads", "url": `${siteUrl}/contact` };
const breadcrumb = { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type":"ListItem","position":1,"name":"Home","item":siteUrl},{"@type":"ListItem","position":2,"name":"Contact","item":`${siteUrl}/contact`}] };
---
<Base title="Contact Us | Harmony Threads" description="Get in touch with Harmony Threads — we answer every message within 1 business day. Reach us about orders, returns, or anything else." structuredData={[contactSchema, breadcrumb]}>
  <div class="pt-28 pb-24 px-6 lg:px-12 max-w-5xl mx-auto">
    <nav class="text-xs text-[#6b6155] mb-8 flex items-center gap-2"><a href="/" class="hover:text-[#c0392b]">Home</a><span>/</span><span>Contact</span></nav>
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Get in touch</p>
        <h1 class="font-display text-4xl lg:text-5xl font-bold leading-tight mb-6">Every message<br />gets a reply.</h1>
        <p class="text-[#6b6155] leading-relaxed mb-8">Whether you have a question about sizing, need help with an order, or just want to talk about The Band — we're here. Replies within 1 business day.</p>
        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#f0ece4] rounded-sm flex items-center justify-center flex-shrink-0"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
            <div><p class="text-sm font-semibold">Email</p><p class="text-sm text-[#6b6155]">hello@harmonythreads.com</p></div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-[#f0ece4] rounded-sm flex items-center justify-center flex-shrink-0"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c0392b" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div><p class="text-sm font-semibold">Response time</p><p class="text-sm text-[#6b6155]">Within 1 business day</p></div>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-[#e8e2d6]">
          <p class="text-sm font-semibold mb-3">Frequently asked first</p>
          <a href="/faq" class="text-sm text-[#c0392b] hover:underline flex items-center gap-1">Visit our FAQ page <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
      <div>
        <form id="contact-form" class="space-y-5">
          <input type="hidden" name="renderedAt" id="rendered-at" />
          <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />
          <div><label class="block text-sm font-medium mb-1.5" for="contact-name">Your name</label><input type="text" id="contact-name" name="name" required placeholder="Jane Smith" class="w-full px-4 py-3 border border-[#e8e2d6] bg-white text-sm focus:outline-none focus:border-[#c0392b] transition-colors" /></div>
          <div><label class="block text-sm font-medium mb-1.5" for="contact-email">Email address</label><input type="email" id="contact-email" name="email" required placeholder="jane@example.com" class="w-full px-4 py-3 border border-[#e8e2d6] bg-white text-sm focus:outline-none focus:border-[#c0392b] transition-colors" /></div>
          <div><label class="block text-sm font-medium mb-1.5" for="contact-message">Message</label><textarea id="contact-message" name="message" required rows="5" placeholder="Tell us about your order, sizing question, or anything else…" class="w-full px-4 py-3 border border-[#e8e2d6] bg-white text-sm focus:outline-none focus:border-[#c0392b] transition-colors resize-none"></textarea></div>
          <button type="submit" class="btn-primary w-full text-sm py-3">Send message</button>
          <p id="contact-msg" class="text-sm text-center hidden"></p>
        </form>
      </div>
    </div>
  </div>
</Base>
<script>
  document.getElementById('rendered-at')!.value = Date.now().toString();
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const msgEl = document.getElementById('contact-msg')!;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Sending…';
    try {
      const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: fd.get('name'), email: fd.get('email'), message: fd.get('message'), website: fd.get('website'), renderedAt: fd.get('renderedAt') }) });
      const json = await res.json();
      msgEl.textContent = json.message ?? json.error ?? 'Done!';
      msgEl.className = `text-sm text-center ${res.ok ? 'text-green-700' : 'text-red-600'}`;
      msgEl.classList.remove('hidden');
      if (res.ok) form.reset();
    } catch { msgEl.textContent = 'Something went wrong.'; msgEl.className = 'text-sm text-center text-red-600'; msgEl.classList.remove('hidden'); }
    finally { btn.disabled = false; btn.textContent = 'Send message'; }
  });
</script>
