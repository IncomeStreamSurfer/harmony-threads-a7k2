---
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { anonClient } from "../../lib/supabase";

const sb = anonClient();
let posts: any[] = [];
if (sb) {
  const { data } = await sb.from("content").select("slug, title, excerpt, cover_image_url, tags, published_at").not("published_at", "is", null).order("published_at", { ascending: false }).limit(12);
  posts = data ?? [];
}
---
<Base title="Stories — Music History & Rock Culture | Harmony Threads" description="Deep reads on rock music history, band stories, and the culture behind the clothes.">
  <div class="pt-28 pb-24 px-6 lg:px-12 max-w-5xl mx-auto">
    <nav class="text-xs text-[#6b6155] mb-8 flex items-center gap-2"><a href="/" class="hover:text-[#c0392b]">Home</a><span>/</span><span>Stories</span></nav>
    <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-4">The journal</p>
    <h1 class="font-display text-4xl lg:text-5xl font-bold leading-tight mb-4">Stories worth reading</h1>
    <p class="text-[#6b6155] text-lg max-w-xl mb-16">Rock history, band deep-dives, style guides. Written for the fans who love the music and the culture around it.</p>
    {posts.length === 0 ? (
      <div class="text-center py-20 border border-[#e8e2d6] rounded-sm bg-white">
        <p class="font-display text-2xl font-semibold mb-3">Fresh articles coming soon.</p>
        <p class="text-[#6b6155] text-sm mb-6">Sign up below to be the first to know when we publish.</p>
        <form id="blog-subscribe" class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
          <input type="hidden" name="renderedAt" id="blog-rendered-at" />
          <input type="text" name="website" aria-hidden="true" tabindex="-1" autocomplete="off" style="position:absolute;left:-9999px;opacity:0" />
          <input type="email" name="email" required placeholder="your@email.com" class="flex-1 px-4 py-2.5 border border-[#e8e2d6] text-sm focus:outline-none focus:border-[#c0392b]" />
          <button type="submit" class="btn-primary text-sm px-5 py-2.5">Notify me</button>
        </form>
        <p id="blog-subscribe-msg" class="text-sm mt-2 hidden"></p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 gap-10">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} class="group">
            {post.cover_image_url && (<div class="aspect-video overflow-hidden rounded-sm bg-[#f0ece4] mb-4"><img src={post.cover_image_url} alt={post.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" /></div>)}
            <div>
              <p class="text-xs text-[#6b6155] uppercase tracking-widest mb-2">{new Date(post.published_at).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' })}</p>
              <h2 class="font-display text-xl font-semibold leading-snug mb-2 group-hover:text-[#c0392b] transition-colors">{post.title}</h2>
              {post.excerpt && <p class="text-sm text-[#6b6155] leading-relaxed line-clamp-3">{post.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
<script>
  document.getElementById('blog-rendered-at')?.setAttribute('value', Date.now().toString());
  document.getElementById('blog-subscribe')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const msgEl = document.getElementById('blog-subscribe-msg')!;
    try {
      const res = await fetch('/api/subscribe', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email: fd.get('email'), website: fd.get('website'), renderedAt: fd.get('renderedAt') }) });
      const json = await res.json();
      msgEl.textContent = json.message ?? "You're in!";
      msgEl.className = 'text-sm mt-2 text-green-700';
      msgEl.classList.remove('hidden');
      form.reset();
    } catch { msgEl.textContent = 'Something went wrong.'; msgEl.className = 'text-sm mt-2 text-red-600'; msgEl.classList.remove('hidden'); }
  });
</script>
