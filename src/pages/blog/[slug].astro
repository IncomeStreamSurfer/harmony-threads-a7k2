---
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { anonClient } from "../../lib/supabase";
import { safeHtml } from "../../lib/sanitize";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/blog");

const sb = anonClient();
if (!sb) return new Response("Server error", { status: 500 });

const { data: post } = await sb.from("content").select("slug, title, body, excerpt, cover_image_url, tags, seo_title, seo_description, published_at, updated_at").eq("slug", slug).not("published_at", "is", null).maybeSingle();

if (!post) return new Response("Not found", { status: 404 });

const siteUrl = Astro.site?.toString() ?? "https://harmony-threads-a7k2.vercel.app";
const articleSchema = { "@context": "https://schema.org", "@type": "BlogPosting", "headline": post.title, "datePublished": post.published_at, "author": { "@type": "Organization", "name": "Harmony Threads" } };

function mdToHtml(md: string): string {
  return md.replace(/^### (.+)$/gm,'<h3>$1</h3>').replace(/^## (.+)$/gm,'<h2>$1</h2>').replace(/^# (.+)$/gm,'<h1>$1</h1>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/\*(.+?)\*/g,'<em>$1</em>').replace(/\n\n/g,'</p><p>').replace(/^(?!<)(.+)$/gm,'<p>$1</p>').trim();
}
---
<Base title={post.seo_title ?? `${post.title} | Harmony Threads`} description={post.seo_description ?? post.excerpt ?? ""} ogImage={post.cover_image_url ?? undefined} ogType="article" publishDate={post.published_at} structuredData={articleSchema} tags={post.tags ?? []}>
  <article class="pt-28 pb-24 px-6 max-w-3xl mx-auto">
    <nav class="text-xs text-[#6b6155] mb-8 flex items-center gap-2"><a href="/" class="hover:text-[#c0392b]">Home</a><span>/</span><a href="/blog" class="hover:text-[#c0392b]">Stories</a><span>/</span><span class="truncate max-w-xs">{post.title}</span></nav>
    {post.cover_image_url && (<div class="aspect-video overflow-hidden rounded-sm bg-[#f0ece4] mb-10"><img src={post.cover_image_url} alt={post.title} class="w-full h-full object-cover" loading="eager" /></div>)}
    <header class="mb-10">
      <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-3">{new Date(post.published_at).toLocaleDateString('en-GB', { day:'numeric', month:'long', year:'numeric' })}</p>
      <h1 class="font-display text-4xl lg:text-5xl font-bold leading-tight mb-4">{post.title}</h1>
      {post.excerpt && <p class="text-[#6b6155] text-xl leading-relaxed">{post.excerpt}</p>}
    </header>
    <div class="prose prose-lg max-w-none text-[#3a3a3a]" set:html={safeHtml(mdToHtml(post.body ?? ""))} />
    <div class="mt-16 pt-10 border-t border-[#e8e2d6] grid sm:grid-cols-2 gap-4">
      <a href="/shop" class="flex items-center gap-3 p-4 border border-[#e8e2d6] rounded-sm hover:border-[#c0392b] transition-colors group"><div><p class="text-xs text-[#6b6155] uppercase tracking-widest mb-1">Shop now</p><p class="text-sm font-semibold group-hover:text-[#c0392b] transition-colors">Browse the collection →</p></div></a>
      <a href="/blog" class="flex items-center gap-3 p-4 border border-[#e8e2d6] rounded-sm hover:border-[#c0392b] transition-colors group"><div><p class="text-xs text-[#6b6155] uppercase tracking-widest mb-1">More stories</p><p class="text-sm font-semibold group-hover:text-[#c0392b] transition-colors">All articles →</p></div></a>
    </div>
  </article>
</Base>
