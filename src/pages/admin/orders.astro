---
export const prerender = false;
import Base from "../../layouts/Base.astro";
import { anonClient } from "../../lib/supabase";

const sb = anonClient();
let orders: any[] = [];
if (sb) {
  // Note: orders need service_role to read. This page shows from anon client (limited).
  try {
    const { data } = await sb.from("orders").select("id, stripe_session_id, customer_email, amount_total_pence, currency, status, created_at").order("created_at", { ascending: false }).limit(50);
    orders = data ?? [];
  } catch { orders = []; }
}
---
<Base title="Orders — Admin | Harmony Threads" description="" noindex={true}>
  <div class="pt-28 pb-24 px-6 lg:px-12 max-w-5xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
      <a href="/admin" class="text-sm text-[#6b6155] hover:text-[#c0392b]">← Dashboard</a>
      <h1 class="font-display text-3xl font-bold">Orders</h1>
    </div>
    {orders.length === 0 ? (
      <div class="text-center py-20 border border-[#e8e2d6] rounded-sm bg-white">
        <p class="text-[#6b6155]">No orders yet. Orders appear here after customers checkout via Stripe.</p>
      </div>
    ) : (
      <div class="bg-white border border-[#e8e2d6] rounded-sm overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-[#f0ece4] border-b border-[#e8e2d6]"><tr><th class="text-left px-4 py-3 font-semibold">Order ID</th><th class="text-left px-4 py-3 font-semibold">Customer</th><th class="text-left px-4 py-3 font-semibold">Total</th><th class="text-left px-4 py-3 font-semibold">Status</th><th class="text-left px-4 py-3 font-semibold">Date</th></tr></thead>
          <tbody class="divide-y divide-[#e8e2d6]">
            {orders.map(o => (
              <tr class="hover:bg-[#faf7f2]">
                <td class="px-4 py-3 font-mono text-xs">{o.stripe_session_id?.slice(-10).toUpperCase()}</td>
                <td class="px-4 py-3 text-[#6b6155]">{o.customer_email ?? '—'}</td>
                <td class="px-4 py-3 font-semibold">£{((o.amount_total_pence ?? 0) / 100).toFixed(2)}</td>
                <td class="px-4 py-3"><span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 text-green-700">{o.status}</span></td>
                <td class="px-4 py-3 text-[#6b6155]">{new Date(o.created_at).toLocaleDateString('en-GB')}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</Base>
