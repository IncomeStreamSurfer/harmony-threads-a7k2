---
export const prerender = false;
import Base from "../layouts/Base.astro";
import { anonClient } from "../lib/supabase";
import { safeHtml } from "../lib/sanitize";

const sb = anonClient();
let faqs: any[] = [];
if (sb) {
  const { data } = await sb.from("faqs").select("question, answer_html, sort_order").order("sort_order");
  faqs = data ?? [];
}

const siteUrl = Astro.site?.toString() ?? "https://harmony-threads-a7k2.vercel.app";
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.question, "acceptedAnswer": { "@type": "Answer", "text": f.answer_html?.replace(/<[^>]+>/g, "") ?? "" } }))
};
---
<Base title="Frequently Asked Questions | Harmony Threads" description="Answers to the most common questions about ordering, shipping, returns, sizing and digital downloads at Harmony Threads." structuredData={faqSchema}>
  <div class="pt-28 pb-24 px-6 lg:px-12 max-w-3xl mx-auto">
    <nav class="text-xs text-[#6b6155] mb-8 flex items-center gap-2"><a href="/" class="hover:text-[#c0392b]">Home</a><span>/</span><span>FAQ</span></nav>
    <p class="text-[#c0392b] text-xs font-semibold uppercase tracking-[0.2em] mb-4">Questions answered</p>
    <h1 class="font-display text-4xl lg:text-5xl font-bold leading-tight mb-12">Frequently asked questions</h1>
    {faqs.length === 0 ? (
      <p class="text-[#6b6155]">FAQs coming soon. <a href="/contact" class="text-[#c0392b] hover:underline">Contact us</a> directly in the meantime.</p>
    ) : (
      <div class="space-y-0 divide-y divide-[#e8e2d6]">
        {faqs.map((faq, i) => (
          <details class="group py-6" open={i === 0}>
            <summary class="flex items-center justify-between cursor-pointer list-none">
              <h2 class="font-semibold text-[#1a1009] pr-8">{faq.question}</h2>
              <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-[#6b6155] group-open:rotate-45 transition-transform"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span>
            </summary>
            <div class="mt-4 text-[#3a3a3a] leading-relaxed text-sm prose prose-sm max-w-none" set:html={safeHtml(faq.answer_html ?? "")} />
          </details>
        ))}
      </div>
    )}
    <div class="mt-16 bg-[#f0ece4] rounded-sm p-8 text-center">
      <h2 class="font-display text-2xl font-semibold mb-3">Still have a question?</h2>
      <p class="text-[#6b6155] text-sm mb-6">We reply to every message within 1 business day.</p>
      <a href="/contact" class="btn-primary text-sm">Contact us</a>
    </div>
  </div>
</Base>
