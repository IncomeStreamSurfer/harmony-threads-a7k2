---
import SEOHead from "../components/SEOHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  structuredData?: object | object[];
  noindex?: boolean;
  tags?: string[];
}

const { title, description, ogImage, ogType, canonicalUrl, structuredData, noindex, tags } = Astro.props;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Harmony Threads",
  "url": Astro.site?.toString() ?? "https://harmony-threads-a7k2.vercel.app",
  "logo": (Astro.site?.toString() ?? "https://harmony-threads-a7k2.vercel.app") + "/favicon.svg",
  "sameAs": []
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={title}
    description={description}
    ogImage={ogImage}
    ogType={ogType}
    canonicalUrl={canonicalUrl}
    structuredData={structuredData ? [orgSchema, ...(Array.isArray(structuredData) ? structuredData : [structuredData])] : [orgSchema]}
    noindex={noindex}
    tags={tags}
  />
</head>
<body class="bg-[#faf7f2] text-[#1a1009] font-body">
  <header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    <nav class="flex items-center justify-between px-6 lg:px-12 py-4 max-w-7xl mx-auto">
      <a href="/" class="flex items-center gap-2 group">
        <span class="inline-block w-7 h-7 rounded-full bg-[#c0392b] flex items-center justify-center text-white text-xs font-bold">H</span>
        <span class="font-display text-xl font-semibold tracking-tight text-[#1a1009]">Harmony Threads</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="/shop" class="text-sm font-medium text-[#3a3a3a] hover:text-[#c0392b] transition-colors">Shop</a>
        <a href="/about" class="text-sm font-medium text-[#3a3a3a] hover:text-[#c0392b] transition-colors">About</a>
        <a href="/blog" class="text-sm font-medium text-[#3a3a3a] hover:text-[#c0392b] transition-colors">Stories</a>
        <a href="/contact" class="text-sm font-medium text-[#3a3a3a] hover:text-[#c0392b] transition-colors">Contact</a>
      </div>
      <div class="flex items-center gap-4">
        <button id="cart-toggle" class="relative flex items-center gap-1.5 text-sm font-medium text-[#1a1009] hover:text-[#c0392b] transition-colors" aria-label="Open cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span id="cart-count" class="hidden absolute -top-1.5 -right-1.5 bg-[#c0392b] text-white text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center">0</span>
        </button>
        <button id="mobile-menu-toggle" class="md:hidden" aria-label="Menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>
    <div id="mobile-menu" class="hidden md:hidden bg-[#faf7f2] border-t border-[#e8e2d6] px-6 py-4">
      <div class="flex flex-col gap-4">
        <a href="/shop" class="text-base font-medium">Shop</a>
        <a href="/about" class="text-base font-medium">About</a>
        <a href="/blog" class="text-base font-medium">Stories</a>
        <a href="/contact" class="text-base font-medium">Contact</a>
      </div>
    </div>
  </header>

  <div id="cart-overlay" class="fixed inset-0 bg-black/40 z-40 hidden opacity-0 transition-opacity duration-300"></div>
  <aside id="cart-drawer" class="fixed top-0 right-0 h-full w-full max-w-sm bg-[#faf7f2] z-50 translate-x-full transition-transform duration-300 shadow-2xl flex flex-col">
    <div class="flex items-center justify-between px-6 py-5 border-b border-[#e8e2d6]">
      <h2 class="font-display text-xl font-semibold">Your Cart</h2>
      <button id="cart-close" aria-label="Close cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4">
      <p class="text-[#6b6155] text-sm" id="cart-empty-msg">Your cart is empty.</p>
    </div>
    <div class="px-6 py-5 border-t border-[#e8e2d6]">
      <div class="flex items-center justify-between mb-4">
        <span class="font-medium">Total</span>
        <span id="cart-total" class="font-display text-xl font-semibold">£0.00</span>
      </div>
      <button id="checkout-btn" class="btn-primary w-full text-center text-sm py-3" disabled>
        Checkout
      </button>
      <p class="text-xs text-[#6b6155] mt-2 text-center">Secure checkout via Stripe</p>
    </div>
  </aside>

  <main>
    <slot />
  </main>

  <footer class="bg-[#1a1009] text-[#faf7f2] mt-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="inline-block w-7 h-7 rounded-full bg-[#c0392b] flex items-center justify-center text-white text-xs font-bold">H</span>
            <span class="font-display text-xl font-semibold">Harmony Threads</span>
          </div>
          <p class="text-sm text-[#a09080] leading-relaxed">Wear the music you love.<br />Premium rock merch for real fans,<br />curated since 2024.</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-widest text-[#a09080] mb-4">Shop</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/shop" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">All Products</a></li>
            <li><a href="/shop?type=tshirt" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">Graphic Tees</a></li>
            <li><a href="/shop?type=digital" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">Digital Downloads</a></li>
            <li><a href="/faq" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">FAQ</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-widest text-[#a09080] mb-4">Company</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/about" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">About Us</a></li>
            <li><a href="/blog" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">Stories</a></li>
            <li><a href="/contact" class="text-[#e8e2d6] hover:text-[#c0392b] transition-colors">Contact</a></li>
          </ul>
          <div class="mt-6">
            <p class="text-xs text-[#6b6155]">Harmony Threads<br />London, UK</p>
          </div>
        </div>
      </div>
      <div class="mt-12 pt-8 border-t border-[#2d2018] flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-xs text-[#6b6155]">© 2026 Harmony Threads. All rights reserved.</p>
        <p class="text-xs text-[#6b6155]">Made for music lovers.</p>
      </div>
    </div>
  </footer>

  <script>
    const header = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        header?.classList.add('bg-[#faf7f2]/95', 'backdrop-blur-sm', 'border-b', 'border-[#e8e2d6]');
      } else {
        header?.classList.remove('bg-[#faf7f2]/95', 'backdrop-blur-sm', 'border-b', 'border-[#e8e2d6]');
      }
    });
    document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
    const cartToggle = document.getElementById('cart-toggle');
    const cartClose = document.getElementById('cart-close');
    const cartOverlay = document.getElementById('cart-overlay');
    const cartDrawer = document.getElementById('cart-drawer');
    function openCart() {
      cartOverlay?.classList.remove('hidden');
      setTimeout(() => cartOverlay?.classList.remove('opacity-0'), 10);
      cartDrawer?.classList.remove('translate-x-full');
    }
    function closeCart() {
      cartOverlay?.classList.add('opacity-0');
      cartDrawer?.classList.add('translate-x-full');
      setTimeout(() => cartOverlay?.classList.add('hidden'), 300);
    }
    cartToggle?.addEventListener('click', openCart);
    cartClose?.addEventListener('click', closeCart);
    cartOverlay?.addEventListener('click', closeCart);
    function getCart() {
      try { return JSON.parse(localStorage.getItem('ht_cart') ?? '[]'); } catch { return []; }
    }
    function renderCart() {
      const items = getCart();
      const countEl = document.getElementById('cart-count');
      const totalEl = document.getElementById('cart-total');
      const itemsEl = document.getElementById('cart-items');
      const emptyEl = document.getElementById('cart-empty-msg');
      const checkoutBtn = document.getElementById('checkout-btn') as HTMLButtonElement | null;
      const total = items.reduce((s: number, i: any) => s + i.price_pence * i.qty, 0);
      const count = items.reduce((s: number, i: any) => s + i.qty, 0);
      if (countEl) {
        if (count > 0) { countEl.textContent = count > 9 ? '9+' : String(count); countEl.classList.remove('hidden'); }
        else { countEl.classList.add('hidden'); }
      }
      if (totalEl) totalEl.textContent = `£${(total / 100).toFixed(2)}`;
      if (emptyEl) emptyEl.style.display = items.length ? 'none' : '';
      if (itemsEl) {
        Array.from(itemsEl.querySelectorAll('.cart-item')).forEach(el => el.remove());
        items.forEach((item: any) => {
          const div = document.createElement('div');
          div.className = 'cart-item flex gap-3 mb-4';
          div.innerHTML = `<img src="${item.image_url}" alt="${item.name}" class="w-16 h-16 object-cover rounded-sm" /><div class="flex-1 min-w-0"><p class="text-sm font-medium truncate">${item.name}</p><p class="text-xs text-[#6b6155] mt-0.5">${[item.size, item.color].filter(Boolean).join(' / ')}</p><div class="flex items-center justify-between mt-1"><div class="flex items-center gap-2"><button class="qty-dec text-[#6b6155] hover:text-[#1a1009] text-lg leading-none" data-id="${item.product_id}" data-sku="${item.variant_sku}">−</button><span class="text-sm w-5 text-center">${item.qty}</span><button class="qty-inc text-[#6b6155] hover:text-[#1a1009] text-lg leading-none" data-id="${item.product_id}" data-sku="${item.variant_sku}">+</button></div><span class="text-sm font-semibold">£${((item.price_pence * item.qty) / 100).toFixed(2)}</span></div></div><button class="cart-remove text-[#6b6155] hover:text-[#c0392b] self-start mt-0.5" data-id="${item.product_id}" data-sku="${item.variant_sku}" aria-label="Remove"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>`;
          itemsEl.appendChild(div);
        });
        itemsEl.querySelectorAll('.qty-dec').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.id!; const sku = (btn as HTMLElement).dataset.sku!;
            const cart = getCart(); const item = cart.find((i: any) => i.product_id === id && i.variant_sku === sku);
            if (item) { item.qty = Math.max(0, item.qty - 1); const updated = item.qty === 0 ? cart.filter((i: any) => !(i.product_id === id && i.variant_sku === sku)) : cart; localStorage.setItem('ht_cart', JSON.stringify(updated)); renderCart(); }
          });
        });
        itemsEl.querySelectorAll('.qty-inc').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.id!; const sku = (btn as HTMLElement).dataset.sku!;
            const cart = getCart(); const item = cart.find((i: any) => i.product_id === id && i.variant_sku === sku);
            if (item) { item.qty++; localStorage.setItem('ht_cart', JSON.stringify(cart)); renderCart(); }
          });
        });
        itemsEl.querySelectorAll('.cart-remove').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.id!; const sku = (btn as HTMLElement).dataset.sku!;
            const updated = getCart().filter((i: any) => !(i.product_id === id && i.variant_sku === sku));
            localStorage.setItem('ht_cart', JSON.stringify(updated)); renderCart();
          });
        });
      }
      if (checkoutBtn) checkoutBtn.disabled = items.length === 0;
    }
    document.getElementById('checkout-btn')?.addEventListener('click', async () => {
      const items = getCart(); if (!items.length) return;
      const btn = document.getElementById('checkout-btn') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Redirecting…';
      try {
        const res = await fetch('/api/checkout', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ items: items.map((i: any) => ({ product_id: i.product_id, qty: i.qty, variant_sku: i.variant_sku })) }) });
        const { url, error } = await res.json();
        if (error || !url) throw new Error(error ?? 'Checkout failed');
        window.location.href = url;
      } catch (err: any) {
        alert('Checkout failed: ' + err.message); btn.disabled = false; btn.textContent = 'Checkout';
      }
    });
    window.addEventListener('cart-updated', () => renderCart());
    renderCart();
  </script>
</body>
</html>
